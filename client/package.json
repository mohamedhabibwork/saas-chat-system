{
  "name": "platform-sdk",
  "version": "1.0.0",
  "description": "SDK for integrating with the platform",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && rollup -c",
    "build:types": "tsc --emitDeclarationOnly",
    "test": "jest",
    "lint": "eslint 'ts/**/*.ts'",
    "format": "prettier --write 'ts/**/*.ts'",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint"
  },
  "keywords": [
    "sdk",
    "api",
    "platform",
    "communication",
    "file-sharing",
    "webrtc",
    "chat"
  ],
  "author": "Platform Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-organization/platform-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/your-organization/platform-sdk/issues"
  },
  "homepage": "https://github.com/your-organization/platform-sdk#readme",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^22.0.0",
    "@rollup/plugin-node-resolve": "^13.3.0",
    "@rollup/plugin-typescript": "^8.3.2",
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.11",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
    "@typescript-eslint/parser": "^5.57.1",
    "eslint": "^8.37.0",
    "jest": "^29.5.0",
    "prettier": "^2.8.7",
    "rimraf": "^4.4.1",
    "rollup": "^3.20.2",
    "rollup-plugin-terser": "^7.0.2",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.3"
  },
  "dependencies": {
    "isomorphic-fetch": "^3.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "browser": {
    "./dist/node": "./dist/browser"
  },
  "publishConfig": {
    "access": "public"
  }
} 